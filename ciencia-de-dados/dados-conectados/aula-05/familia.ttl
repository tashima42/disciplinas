@prefix : <http://www.semanticweb.org/familia#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/familia#> .

<http://www.semanticweb.org/familia> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/familia#conjuge
:conjuge rdf:type owl:ObjectProperty ;
         rdfs:domain :Pessoa ;
         rdfs:range :Pessoa .


###  http://www.semanticweb.org/familia#eTio
:eTio rdf:type owl:ObjectProperty ;
      owl:propertyChainAxiom ( :temIrmao
                               :temFilho
                             ) .


###  http://www.semanticweb.org/familia#temFilho
:temFilho rdf:type owl:ObjectProperty ;
          owl:inverseOf :temPais ;
          rdfs:domain :Pessoa ;
          rdfs:range :Pessoa .


###  http://www.semanticweb.org/familia#temIrmao
:temIrmao rdf:type owl:ObjectProperty ,
                   owl:TransitiveProperty ;
          rdfs:domain :Pessoa ;
          rdfs:range :Pessoa .


###  http://www.semanticweb.org/familia#temMae
:temMae rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf :temPais ;
        rdfs:domain :Pessoa ;
        rdfs:range :Mulher .


###  http://www.semanticweb.org/familia#temPai
:temPai rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf :temPais ;
        rdfs:domain :Pessoa ;
        rdfs:range :Homem .


###  http://www.semanticweb.org/familia#temPais
:temPais rdf:type owl:ObjectProperty ;
         rdfs:domain :Pessoa ;
         rdfs:range :Pessoa .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/familia#Homem
:Homem rdf:type owl:Class ;
       rdfs:subClassOf :Pessoa ;
       owl:disjointWith :Mulher .


###  http://www.semanticweb.org/familia#Mulher
:Mulher rdf:type owl:Class ;
        rdfs:subClassOf :Pessoa .


###  http://www.semanticweb.org/familia#Pessoa
:Pessoa rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :temMae ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :Mulher
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :temPai ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :Homem
                        ] .


#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/familia#André
:André rdf:type owl:NamedIndividual ,
                :Homem ,
                :Pessoa .


###  http://www.semanticweb.org/familia#Felipe
:Felipe rdf:type owl:NamedIndividual ,
                 :Homem ,
                 :Pessoa ;
        :temIrmao :Sabrina .


###  http://www.semanticweb.org/familia#João
:João rdf:type owl:NamedIndividual ,
               :Homem ,
               :Pessoa ;
      :temIrmao :Sabrina ;
      :temMae :Maria ;
      :temPai :André .


###  http://www.semanticweb.org/familia#Marcos
:Marcos rdf:type owl:NamedIndividual ,
                 :Homem ,
                 :Pessoa ;
        :temIrmao :André .


###  http://www.semanticweb.org/familia#Maria
:Maria rdf:type owl:NamedIndividual ,
                :Mulher ,
                :Pessoa .


###  http://www.semanticweb.org/familia#Paulo
:Paulo rdf:type owl:NamedIndividual ,
                :Homem ,
                :Pessoa ;
       :temMae :Maria .


###  http://www.semanticweb.org/familia#Sabrina
:Sabrina rdf:type owl:NamedIndividual ,
                  :Mulher ,
                  :Pessoa ;
         :temIrmao :Felipe .


